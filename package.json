    "test": "vitest --run"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tktb-tess/util-fns": "^0.13.3",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "neverthrow": "^8.2.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.1"
