{
  "name": "bf-playground",
  "private": true,
  "version": "0.1.0-alpha.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:wasm": "./scripts/build_wasm.sh",
    "build": "vite build",
    "build:full": "./scripts/build_wasm.sh && vite build",
    "preview": "vite preview",
    "build-preview": "vite build && vite preview",
